# Environment
NODE_ENV=development
PORT=3000

# Telegram - Replace with your actual values in production
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Database
DATABASE_URL="file:./dev.db"

# Default thresholds
PAGESPEED_CRITICAL=50
PAGESPEED_WARNING=75
UPTIME_MINIMUM=99

# Scheduler (cron expression)
UPTIME_CRON="*/30 * * * *"
WPO_CRON="0 */2 * * *"
SEO_CRON="0 */4 * * *"